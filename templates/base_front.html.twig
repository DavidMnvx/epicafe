<!doctype html>
<html lang="fr" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  {% set _meta_title = block('title') %}
  {% set _meta_description = block('meta_description') %}
  {% set _og_image = absolute_url(site_image('home_hero', 'images/Accueil-2.jpg')) %}

  <title>{% block title %}L'Épi-Café — Bar & Épicerie locale au pied du Ventoux{% endblock %}</title>
  <meta name="description" content="{% block meta_description %}{{ setting('site_tagline', 'Bar & Épicerie locale au pied du Mont Ventoux, au cœur du Barroux.') }}{% endblock %}">

  <!-- Favicon -->
  <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
  <link rel="alternate icon" href="{{ asset('favicon.ico') }}">
  <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">
  <meta name="theme-color" content="#2d685f">

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp, etc.) -->
  <meta property="og:type"        content="website">
  <meta property="og:site_name"   content="L'Épi-Café">
  <meta property="og:locale"      content="fr_FR">
  <meta property="og:title"       content="{{ _meta_title }}">
  <meta property="og:description" content="{{ _meta_description }}">
  <meta property="og:url"         content="{{ app.request.uri }}">
  <meta property="og:image"       content="{{ _og_image }}">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ _meta_title }}">
  <meta name="twitter:description" content="{{ _meta_description }}">
  <meta name="twitter:image"       content="{{ _og_image }}">

  <!-- Préconnexion Google Fonts (réduit le FOUT en parallélisant DNS + TLS) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Polices d'abord, pour qu'elles commencent à télécharger en parallèle de la CSS -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Cormorant+Garamond:wght@300;400;600&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="{{ asset('styles/front.css') }}">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css">
</head>

<body class="{{ bodyClass|default('') }}">

{# ============================================================
   BANDEAU FERMETURE EXCEPTIONNELLE — édité depuis l'admin
   Effet glassmorphism + texte défilant en boucle (ticker)
   ============================================================ #}
{% if setting_bool('closure_active') and setting('closure_message') %}
  {% set closureMsg = setting('closure_message')|striptags|trim|replace({"\n": ' · ', "\r": ''}) %}
  <aside class="vv-closureTicker" role="status" aria-live="polite">
    <div class="vv-closureTicker__icon" aria-hidden="true">
      <span class="vv-closureTicker__dot"></span>
    </div>
    <div class="vv-closureTicker__viewport">
      <div class="vv-closureTicker__track">
        {# Le contenu est dupliqué pour permettre une boucle fluide #}
        {% for _ in 1..3 %}
          <span class="vv-closureTicker__msg">
            <strong>Information</strong>
            <span aria-hidden="true">—</span>
            {{ closureMsg }}
            <span class="vv-closureTicker__sep" aria-hidden="true">✦</span>
          </span>
        {% endfor %}
      </div>
    </div>
  </aside>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CafeOrCoffeeShop",
  "name": "L'Épi-Café",
  "alternateName": "Épi-Café Le Barroux",
  "description": "Bar, épicerie locale et produits du terroir au cœur du Barroux, au pied du Mont Ventoux.",
  "image": "{{ absolute_url(site_image('home_hero', 'images/Accueil-2.jpg')) }}",
  "url": "{{ absolute_url(path('app_home')) }}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "56 Chemin Neuf",
    "addressLocality": "Le Barroux",
    "postalCode": "84330",
    "addressRegion": "Vaucluse",
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 44.1415,
    "longitude": 5.1980
  },
  "telephone": "+33490123456",
  "priceRange": "€€",
  "servesCuisine": ["Café", "Produits locaux", "Vins du Ventoux"],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday", "Tuesday", "Thursday"], "opens": "07:30", "closes": "18:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Friday", "Saturday"], "opens": "07:30", "closes": "21:30" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "08:00", "closes": "12:00" }
  ]
  {# À compléter une fois les comptes sociaux créés :
  ,"sameAs": [
    "https://www.facebook.com/...",
    "https://www.instagram.com/..."
  ]
  #}
}
</script>

<header class="vv-header" data-vv-header>
  <div class="vv-container">
    <nav class="vv-nav">
      <a href="{{ path('app_home') }}" class="vv-brand">
        <img
          src="{{ asset('images/Logos/Logo-epicafe-removbg.png') }}"
          alt="Épicafé – Le Barroux"
          class="vv-brand__logo"
        >
      </a>

      <ul class="vv-nav__links">
        {% if setting_bool('nav_show_events',   true) %}<li><a href="{{ path('event_index')   }}">Événements</a></li>{% endif %}
        {% if setting_bool('nav_show_gallery',  true) %}<li><a href="{{ path('gallery_index') }}">Galerie Photos</a></li>{% endif %}
        {% if setting_bool('nav_show_partners', true) %}<li><a href="{{ path('partner_index') }}">Partenaires</a></li>{% endif %}
        {% if setting_bool('nav_show_shop',     true) %}<li><a href="{{ path('shop_index')    }}">Boutique</a></li>{% endif %}
        {% if setting_bool('nav_show_menu',     true) %}<li><a href="{{ path('menu')          }}">Menu</a></li>{% endif %}
        {% if setting_bool('nav_show_contact',  true) %}<li><a href="{{ path('contact_index') }}">Contact</a></li>{% endif %}
      </ul>

      <button class="vv-burger"
              type="button"
              aria-label="Ouvrir le menu"
              aria-expanded="false"
              aria-controls="vv-mobile-menu"
              data-vv-burger>
        ☰
      </button>
    </nav>
  </div>

  <div class="vv-mobile" id="vv-mobile-menu" data-vv-mobile>
    <div class="vv-mobile__inner">
      {% if setting_bool('nav_show_events',   true) %}<a href="{{ path('event_index')   }}" data-vv-close-mobile>Événements</a>{% endif %}
      {% if setting_bool('nav_show_gallery',  true) %}<a href="{{ path('gallery_index') }}" data-vv-close-mobile>Galerie Photos</a>{% endif %}
      {% if setting_bool('nav_show_partners', true) %}<a href="{{ path('partner_index') }}" data-vv-close-mobile>Partenaires</a>{% endif %}
      {% if setting_bool('nav_show_shop',     true) %}<a href="{{ path('shop_index')    }}" data-vv-close-mobile>Boutique</a>{% endif %}
      {% if setting_bool('nav_show_menu',     true) %}<a href="{{ path('menu')          }}" data-vv-close-mobile>Menu</a>{% endif %}
      {% if setting_bool('nav_show_contact',  true) %}<a href="{{ path('contact_index') }}" data-vv-close-mobile>Contact</a>{% endif %}
    </div>
  </div>
</header>

{% block javascripts %}
  <script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js" defer></script>
  <script src="{{ asset('scripts/front.js') }}" defer></script>
{% endblock %}

{% block body %}{% endblock %}

{# ============================================================
   AVIS GOOGLE — affiché avant le footer si l'URL est renseignée
   (Paramètres du site → Réseaux sociaux → "Avis Google")
   ============================================================ #}
{% set googleUrl = setting('social_google_reviews') %}
{% if googleUrl %}
  {% set reviews = google_reviews(5) %}
  {% set stats = google_reviews_stats() %}
  {% set googleRating = stats.count > 0 ? (stats.average|number_format(1, ',', ' ')) : '5,0' %}
  {% set googleCount = stats.count %}

  <section class="vv-googleReviews" aria-labelledby="google-reviews-title">
    <div class="vv-container">

      {# ---------- HEADER : logo G + note + nb d'avis + titre ---------- #}
      <div class="vv-googleReviews__top">
        <div class="vv-googleReviews__topLeft">
          <span class="vv-googleReviews__g" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="38" height="38" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0 0 12 23z" fill="#34A853"/>
              <path d="M5.84 14.11A6.6 6.6 0 0 1 5.5 12c0-.73.13-1.45.34-2.11V7.05H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.46 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.07.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A10.99 10.99 0 0 0 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z" fill="#EA4335"/>
            </svg>
          </span>
          <div class="vv-googleReviews__topMeta">
            <p class="vv-kicker">Avis clients Google</p>
            <h2 class="vv-googleReviews__title" id="google-reviews-title">
              Ce qu'en disent nos clients
            </h2>
            {% if googleCount > 0 %}
              <div class="vv-googleReviews__rating">
                <span class="vv-googleReviews__score">{{ googleRating }}</span>
                <span class="vv-googleReviews__stars" aria-hidden="true">★★★★★</span>
                <span class="vv-googleReviews__scoreOver">· {{ googleCount }} avis</span>
              </div>
            {% endif %}
          </div>
        </div>

        <a href="{{ googleUrl }}"
           target="_blank"
           rel="noopener"
           class="vv-googleReviews__btn">
          Laisser un avis
          <span aria-hidden="true">→</span>
        </a>
      </div>

      {# ---------- CAROUSEL DES AVIS — défilement continu (marquee) ---------- #}
      {% if reviews|length > 0 %}
        <div class="vv-reviewsMarquee" data-reviews-marquee>
          <div class="vv-reviewsMarquee__track">
            {# On boucle 2× les avis pour permettre une animation fluide sans saut visible #}
            {% for pass in 1..2 %}
              {% for review in reviews %}
                <article class="vv-reviewCard" {% if pass == 2 %}aria-hidden="true"{% endif %}>
                  <header class="vv-reviewCard__head">
                    <span class="vv-reviewCard__avatar" aria-hidden="true">{{ review.author|slice(0, 1)|upper }}</span>
                    <div class="vv-reviewCard__authorBlock">
                      <strong class="vv-reviewCard__author">{{ review.author }}</strong>
                      {% if review.reviewDate %}
                        <span class="vv-reviewCard__date">{{ review.reviewDate|date('M Y')|capitalize }}</span>
                      {% endif %}
                    </div>
                    <span class="vv-reviewCard__google" aria-label="Avis Google">
                      <svg viewBox="0 0 24 24" width="20" height="20" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0 0 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.11A6.6 6.6 0 0 1 5.5 12c0-.73.13-1.45.34-2.11V7.05H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.46 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.07.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A10.99 10.99 0 0 0 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z" fill="#EA4335"/>
                      </svg>
                    </span>
                  </header>

                  <div class="vv-reviewCard__stars" aria-label="{{ review.rating }} étoiles sur 5">
                    {% for i in 1..review.rating %}★{% endfor %}
                    {% if review.rating < 5 %}
                      {% for i in 1..(5 - review.rating) %}<span class="vv-reviewCard__starEmpty">★</span>{% endfor %}
                    {% endif %}
                  </div>

                  <p class="vv-reviewCard__text">{{ review.text }}</p>
                </article>
              {% endfor %}
            {% endfor %}
          </div>
        </div>
      {% endif %}

      {# ---------- BANDEAU FINAL ---------- #}
      <p class="vv-googleReviews__cta">
        Vous aussi, partagez votre expérience —
        <a href="{{ googleUrl }}" target="_blank" rel="noopener">laissez un avis sur Google</a>.
      </p>

    </div>
  </section>
{% endif %}

<footer class="vv-footer vv-footer--premium">
  <div class="vv-container">

    <div class="vv-footer__grid">

      {# Col 1 : Brand #}
      <div class="vv-footer__col">
        <div class="vv-footer__brand">
          <span class="vv-footer__icon" aria-hidden="true">🍷</span>
          <h3 class="vv-footer__title">Epicafé</h3>
        </div>

        <p class="vv-footer__text">
          Bar – Épicerie – Produits locaux au cœur du village du Barroux, au pied du Mont Ventoux.
        </p>

        <div class="vv-footer__social">
          {% set fb = setting('social_facebook') %}
          {% set insta = setting('social_instagram') %}

          {% if fb %}
            <a class="vv-footer__socialBtn" href="{{ fb }}" target="_blank" rel="noreferrer" aria-label="Facebook">
              <span class="vv-pill">f</span>
              <span class="vv-footer__socialTxt">Facebook</span>
            </a>
          {% endif %}

          {% if insta %}
            <a class="vv-footer__socialBtn" href="{{ insta }}" target="_blank" rel="noreferrer" aria-label="Instagram">
              <span class="vv-pill">📷</span>
              <span class="vv-footer__socialTxt">Instagram</span>
            </a>
          {% endif %}
        </div>
      </div>

      {# Col 2 : Infos #}
      <div class="vv-footer__col">
        <h4 class="vv-footer__h4">Informations</h4>

        <ul class="vv-footer__links vv-footer__links--pills">
          {% set mapsUrl = setting('social_google_maps', 'https://maps.google.com/?q=Le+Barroux+Vaucluse') %}
          <li>
            <a href="{{ mapsUrl }}" target="_blank" rel="noreferrer">
              <span class="vv-pill" aria-hidden="true">📍</span>
              <span>{{ setting('contact_address', 'Le Barroux — Vaucluse')|replace({"\n": ' · '}) }}</span>
            </a>
          </li>

          {% set phone = setting('contact_phone') %}
          {% if phone %}
            <li>
              <a href="tel:{{ phone|replace({' ': '', '.': '', '-': ''}) }}">
                <span class="vv-pill" aria-hidden="true">📞</span>
                <span>{{ phone }}</span>
              </a>
            </li>
          {% endif %}

          {% set email = setting('contact_email') %}
          {% if email %}
            <li>
              <a href="mailto:{{ email }}">
                <span class="vv-pill" aria-hidden="true">✉️</span>
                <span>{{ email }}</span>
              </a>
            </li>
          {% endif %}

          <li>
            <a href="{{ path('menu') }}">
              <span class="vv-pill" aria-hidden="true">🍽️</span>
              <span>Voir la carte</span>
            </a>
          </li>
        </ul>
      </div>

      {# Col 3 : Liens utiles #}
      <div class="vv-footer__col">
        <h4 class="vv-footer__h4">Liens utiles</h4>

        <ul class="vv-footer__links vv-footer__links--pills">
          <li><a href="https://www.laposte.fr/" target="_blank" rel="noreferrer"><span class="vv-pill">📮</span><span>La Poste</span></a></li>
          <li><a href="https://www.ventouxprovence.fr/" target="_blank" rel="noreferrer"><span class="vv-pill">🏔️</span><span>Office de tourisme Ventoux Provence</span></a></li>
          <li><a href="https://www.parcduventoux.fr/" target="_blank" rel="noreferrer"><span class="vv-pill">🌿</span><span>Parc naturel régional du Ventoux</span></a></li>
          <li><a href="https://www.lebarroux.fr/accueil.html" target="_blank" rel="noreferrer"><span class="vv-pill">🏛️</span><span>Mairie de Le Barroux</span></a></li>
          <li><a href="https://www.chateaudubarroux.fr/" target="_blank" rel="noreferrer"><span class="vv-pill">🏰</span><span>Château du Barroux</span></a></li>
        </ul>
      </div>

      {# Col 4 : Découvrir #}
      <div class="vv-footer__col">
        <h4 class="vv-footer__h4">Découvrir</h4>

        <ul class="vv-footer__links vv-footer__links--pills">
          <li><a href="#"><span class="vv-pill">🧭</span><span>Mont Ventoux</span></a></li>
          <li><a href="#"><span class="vv-pill">🏘️</span><span>Villages du Ventoux</span></a></li>
          <li><a href="#"><span class="vv-pill">🫒</span><span>Produits du terroir</span></a></li>
        </ul>
      </div>

    </div>

    <div class="vv-footer__legal">
      <a href="{{ path('legal_mentions') }}">Mentions légales</a>
      <span aria-hidden="true">·</span>
      <a href="{{ path('legal_privacy') }}">Politique de confidentialité</a>
    </div>

    <div class="vv-footer__bottom">
      © {{ "now"|date("Y") }} L'Épi-Café — Tous droits réservés · Site réalisé par <strong>NosWeb</strong>
    </div>

  </div>
</footer>

{# Bandeau RGPD cookies (apparaît au 1er passage si aucun choix stocké) #}
{% include 'components/cookie_banner.html.twig' %}

</body>
</html>