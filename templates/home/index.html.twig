{% extends 'base_front.html.twig' %}

{% block title %}L'Épicerie du Barroux - Bar & Produits locaux au cœur du Ventoux{% endblock %}

{% block body %}

{# HERO #}
<section class="vv-hero" data-vv-hero aria-label="Hero">
  <div class="vv-hero__bg" data-vv-parallax>
    <img
      src="{{ asset('images/Accueil-2.jpg') }}"
      alt="Le Barroux et le Mont Ventoux"
      class="vv-hero__img"
    >
    <div class="vv-hero__overlay"></div>
    <div class="vv-hero__shade"></div>
  </div>

  <div class="vv-hero__content">
    <div class="vv-hero__inner vv-animate-fade-in">
      <h1 class="vv-hero__title">Votre épicerie de village</h1>
      <p class="vv-hero__subtitle">Au pied du Ventoux</p>

    </div>
    <button class="vv-hero__chevron" type="button" aria-label="Descendre" data-vv-scrollto="#bar-section">
      ⌄
    </button>
  </div>
</section>

                                                                       {# SECTION  INTRO #}



<section id="bar-section" class="vv-section vv-section--cream">
  <div class="vv-container">

    <div class="vv-intro vv-scroll-reveal">
      
      <div class="vv-intro__media">
        <img 
          src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=1600&auto=format&fit=crop"
          alt="L’Épicafé au Barroux"
        >
      </div>

      <div class="vv-intro__content">
        <h2 class="vv-h2">Bienvenue à l’Épi-Café</h2>

        <p>
          Au cœur du Barroux, au pied du Ventoux, l’Épicafé est un lieu de vie
          où se croisent habitants, visiteurs et amateurs de bons produits.
        </p>

        <p>
          On s’y retrouve pour un café, un verre de vin, une planche apéritive,
          mais aussi pour les services du quotidien : dépôt de pain,
          point poste, épicerie et restauration rapide le midi.
        </p>

        <p class="vv-intro__links">
          <a href="#events">Événements</a>
          <span>•</span>
          <a href="#products">Produits locaux</a>
          <span>•</span>
          <a href="#contact">Nous trouver</a>
        </p>
      </div>

    </div>

  </div>
</section>


                                                           {# SECTION PLANCHES / VINS / COCKTAILS #}


<section id="apero" class="vv-section vv-section--light" >
  <div class="vv-container" style= "margin-bottom: 4rem;
">
    <div class="vv-apero vv-scroll-reveal">

      <div class="vv-apero__content">
        <p class="vv-kicker">À partager</p>

        <h2 class="vv-h2" style="margin-bottom:.8rem;">
          Planches apéro, bons vins & cocktails
        </h2>

        <p class="vv-lead" style="margin:0; max-width: 60ch;">
          Ici, on aime les choses simples et bien faites : une planche généreuse,
          un verre de Ventoux, et le plaisir de se retrouver.
        </p>

        <ul class="vv-apero__list">
          <li><span class="vv-dot">•</span> Planches charcuterie / fromage (selon arrivage)</li>
          <li><span class="vv-dot">•</span> Vins du Ventoux & découvertes locales</li>
          <li><span class="vv-dot">•</span> Cocktails & boissons fraîches</li>
        </ul>

        <div class="vv-apero__actions">
          <a class="vv-btn vv-btn--primary" href="#events">Voir les événements</a>
          <a class="vv-btn vv-btn--ghost" href="#contact">Nous contacter</a>
        </div>

        <p class="vv-muted vv-apero__note">
          * Suggestions selon la saison — demandez au comptoir 🙂
        </p>
      </div>

      <div class="vv-apero__media" aria-hidden="true">
        <div class="vv-apero__collage">
          <img class="vv-apero__img vv-apero__img--a"
               src="{{ asset('images/apero-3.avif') }}"
               alt="">
          <img class="vv-apero__img vv-apero__img--b"
               src="{{ asset('images/apero-2.avif') }}"
               alt="">
          <img class="vv-apero__img vv-apero__img--c"
               src="{{ asset('images/apero-1.avif') }}"
               alt="">
        </div>
      </div>

    </div>
  </div>
</section>

                                                                             {# BOUTIQUE #}


<section class="vv-section  vv-section--cream">
  <div class="vv-container">

    <div class="vv-section__head">
      <h2 class="vv-h2">Produits locaux</h2>
      <p class="vv-lead">
        Une sélection rigoureuse de produits authentiques de notre région
      </p>
    </div>

    <div class="vv-productsGrid">

      <article class="vv-productCard">
        <img src="{{ asset('images/Produits-locaux-vin.png') }}" alt="Vins du Ventoux">

        <div class="vv-productCard__body">
          <h3>Vins du Ventoux</h3>
          <p>Sélection des meilleurs domaines locaux</p>
        </div>
      </article>

      <article class="vv-productCard">
        <img src="{{ asset('images/Produits-locaux-terroir.png') }}" alt="Produits du terroir">

        <div class="vv-productCard__body">
          <h3>Produits du terroir</h3>
          <p>Huile d'olive, miel, confitures artisanales</p>
        </div>
      </article>

      <article class="vv-productCard">
        <img src="{{ asset('images/Produits-from-char.png') }}" alt="Fromages et charcuterie">

        <div class="vv-productCard__body">
          <h3>Fromages & Charcuterie</h3>
          <p>Produits frais de producteurs locaux</p>
        </div>
      </article>
    </div>

  </div>
</section>

<section class="vv-section vv-section--accent">
  <div class="vv-container vv-center">

    <h2 class="vv-h2">Venez découvrir la boutique</h2>

    <p class="vv-lead">
      Nous vous accueillons au cœur du village du Barroux
    </p>

    <a href="{{ path('shop_index') }}" class="vv-btn vv-btn--primary">
      Boutique
    </a>

  </div>
</section>


                                                                             {# EVENTS #}

<section id="events" class="vv-section vv-section--secondary vv-eventsSection">
  {# Fond parallax #}
  <div class="vv-eventsSection__bg"
       style="background-image:url('{{ asset('images/banners-events.png') }}');">
  </div>
  <div class="vv-eventsSection__veil"></div>

  <div class="vv-container vv-eventsSection__inner">
    <div class="vv-section__head vv-scroll-reveal">
      <h2 class="vv-h2">Événements</h2>
      <p class="vv-lead">À venir à l’Épicafé</p>
    </div>

    {# Récurrents #}
    {% if recurringEvents is defined and recurringEvents|length %}
      <h3 class="vv-h3" style="margin-bottom: 1rem;">Rendez-vous régulier</h3>

      <div class="vv-events">
        {% for event in recurringEvents %}
          {% include 'events/event_row.html.twig' with { event: event } %}
        {% endfor %}
      </div>

      <div style="height: 2rem;"></div>
    {% endif %}

    {# À venir #}
    {% if upcomingEvents is defined and upcomingEvents|length %}
      <div class="vv-events">
        {% for event in upcomingEvents %}
          {% include 'events/event_row.html.twig' with { event: event } %}
        {% endfor %}
      </div>

      <div class="vv-center vv-scroll-reveal" style="margin-top: 1.5rem;">
        <a class="vv-btn vv-btn--primary" href="{{ path('event_index') }}">Voir tous les événements</a>
      </div>
    {% else %}
      <p class="vv-muted">Aucun événement à venir pour le moment.</p>
    {% endif %}
  </div>
</section>


                                                                        {# GALLERY#}

{% if latestPhotos is defined and latestPhotos|length %}
<section id="gallery-preview" class="vv-section vv-section--light">
  <div class="vv-container">
    <div class="vv-section__head vv-scroll-reveal">
      <h2 class="vv-h2">Galerie</h2>
      <p class="vv-lead">Quelques souvenirs des derniers moments à l’Épicafé.</p>
    </div>

    <div class="vv-galleryStrip vv-scroll-reveal" aria-label="Aperçu galerie">
      {% for p in latestPhotos %}
        {% set src = asset('uploads/gallery/' ~ p.fileName) %}
        <a class="vv-galleryStrip__item"
           href="{{ path('gallery_index') }}"
           style="background-image:url('{{ src }}')"
           aria-label="Ouvrir la galerie"></a>
      {% endfor %}
    </div>

    <div class="vv-center vv-scroll-reveal" style="margin-top:1.3rem;">
      <a class="vv-btn vv-btn--primary" href="{{ path('gallery_index') }}">Voir toute la galerie</a>
    </div>
  </div>
</section>
{% endif %}



                                                                        {# SERVICES #}

<section id="services" class="vv-section vv-section--cream">
  <div class="vv-container">
    <div class="vv-section__head vv-scroll-reveal">
      <h2 class="vv-h2">Services pratiques</h2>
      <p class="vv-lead">Plus qu'une épicerie, un véritable service de proximité.</p>
    </div>

    <div class="vv-servicesGrid vv-scroll-reveal">

      <article class="vv-serviceCard">
        <div class="vv-serviceCard__top">
          <div class="vv-serviceCard__icon" aria-hidden="true">🥖</div>

          <div class="vv-serviceCard__head">
            <h3 class="vv-serviceCard__title">Dépôt de pain</h3>
            <p class="vv-serviceCard__subtitle">
              Pain &amp; viennoiseries chaque matin.
            </p>
          </div>
        </div>

        <div class="vv-serviceCard__body">
          <ul class="vv-serviceCard__list">
            <li>Retrait le matin</li>
            <li>Réservation possible</li>
            <li>Selon disponibilité</li>
          </ul>
        </div>

        <div class="vv-serviceCard__footer">
          Boulangerie <strong>Le Beffroi</strong> — Caromb
        </div>
      </article>

      <article class="vv-serviceCard">
        <div class="vv-serviceCard__top">
          <div class="vv-serviceCard__icon">
            <img src="{{ asset('images/Logos/la-poste-logo.svg') }}" alt="La Poste">
          </div>

          <div class="vv-serviceCard__head">
            <h3 class="vv-serviceCard__title">Relais Poste</h3>
            <p class="vv-serviceCard__subtitle">
              Services postaux du quotidien.
            </p>
          </div>
        </div>

        <div class="vv-serviceCard__body">
          <ul class="vv-serviceCard__list">
            <li>Affranchissement</li>
            <li>Colissimo &amp; recommandé</li>
            <li>Services au comptoir</li>
          </ul>
        </div>

        <div class="vv-serviceCard__footer">
          Pratique, local et accessible
        </div>
      </article>

      <article class="vv-serviceCard">
        <div class="vv-serviceCard__top">
          <div class="vv-serviceCard__icon">
            <img src="{{ asset('images/Logos/butagaz-logo.svg') }}" alt="Butagaz">
          </div>

          <div class="vv-serviceCard__head">
            <h3 class="vv-serviceCard__title">Gaz</h3>
            <p class="vv-serviceCard__subtitle">
              Butane &amp; propane selon stock.
            </p>
          </div>
        </div>

        <div class="vv-serviceCard__body">
          <ul class="vv-serviceCard__list">
            <li>Bouteilles butane</li>
            <li>Bouteilles propane</li>
            <li>Informations au comptoir</li>
          </ul>
        </div>

        <div class="vv-serviceCard__footer">
          Échange selon disponibilité
        </div>
      </article>

    </div>

    <div class="vv-servicesHelp vv-scroll-reveal">
      <div class="vv-servicesHelp__inner">
        <strong>Besoin d’un renseignement ?</strong>
        <span>Nous vous accueillons au comptoir pour vous orienter.</span>
      </div>

      <a class="vv-servicesHelp__btn" href="#contact">Nous contacter</a>
    </div>
  </div>
</section>

                                                                        {# CONTACT / MAP / HORAIRES #}


<section id="contact" class="vv-section vv-section--light">
  <div class="vv-container">
    <div class="vv-section__head vv-scroll-reveal">
      <h2 class="vv-h2">Horaires & Contact</h2>
      <p class="vv-lead">Nous sommes là pour vous servir</p>
    </div>

    <div class="vv-contact-grid">
      <div class="vv-stack vv-scroll-reveal">
        <div id="hours" class="vv-panel">
          <h3 class="vv-h3">Horaires d'ouverture</h3>
          <div class="vv-hours">
            <div class="vv-hours__row"><span>Lundi - Mardi et Jeudi </span><b>7h30 - 18h30</b></div>
            <div class="vv-hours__row"><span>Vendredi - Samedi</span><b>7h30 - 21h30</b></div>
            <div class="vv-hours__row"><span>Dimanche</span><b>8h00 - 12h00</b></div>
              <div class="vv-hours__row"><span>Fermé le mercredi</span></div>
          </div>
        </div>

        <div class="vv-panel">
          <h3 class="vv-h3">Informations</h3>
          <div class="vv-info">
            <a href="tel:+33490123456">📞 04 90 12 34 56</a>
            <a href="mailto:epicafebarroux@gmail.com">✉️ contact@epicerie-barroux.fr</a>
            <div>📍 56 Chemin Neuf — 84330 Le Barroux</div>
          </div>
        </div>
      </div>

      <div class="vv-panel vv-scroll-reveal">
        <h3 class="vv-h3">Nous contacter</h3>

        {# Formulaire statique (tu brancheras Symfony Form ensuite) #}
        <form class="vv-form" method="post" action="#">
          <label>
            <span>Nom</span>
            <input type="text" name="name" required>
          </label>

          <label>
            <span>Email</span>
            <input type="email" name="email" required>
          </label>

          <label>
            <span>Message</span>
            <textarea name="message" rows="5" required></textarea>
          </label>

          <button class="vv-btn vv-btn--primary vv-btn--full" type="submit">Envoyer le message</button>
        </form>
      </div>
    </div>

    <div class="vv-map vv-scroll-reveal">
      <iframe
            src="https://www.google.com/maps?q=56%20Chemin%20Neuf%2C%2084330%20Le%20Barroux&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Épicafé - Le Barroux">
      </iframe>
    </div>
      <div class="vv-link-Google"> 
            <a
              href="https://www.google.com/maps?q=56+Chemin+Neuf+84330+Le+Barroux"
              target="_blank"
              rel="noopener"
              class="vv-link"
              >
              🧭 Ouvrir dans Google Maps
              </a>
        </div>
    </div>
</section>

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('scripts/front.js') }}"></script>
{% endblock %}

{% endblock %}
