{# templates/components/page_banner.html.twig #}
{% set _bannerImg = background|default(site_image('banner_events', 'images/banners-events.png')) %}

<section class="vv-miniHero {{ bgClass|default('') }}">
  <div class="vv-miniHero__bg" aria-hidden="true">
    <img
      src="{{ _bannerImg }}"
      alt=""
      class="vv-miniHero__bgImg"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    >
  </div>

  <div class="vv-container vv-miniHero__content">
    <nav class="vv-breadcrumb" aria-label="Fil d’Ariane">
      <a href="{{ path('app_home') }}">Accueil</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{{ title }}</span>
    </nav>

    <h1 class="vv-miniHero__title">{{ title }}</h1>

    {% if subtitle is defined and subtitle %}
      <p class="vv-miniHero__subtitle">{{ subtitle }}</p>
    {% endif %}

    {% if cta is defined and cta %}
      <a class="vv-btn vv-btn--primary vv-miniHero__cta" href="{{ cta.href }}">
        {{ cta.label }} <span aria-hidden="true">→</span>
      </a>
    {% endif %}
  </div>
</section>
