{% extends 'base_front.html.twig' %}
{% set bodyClass = 'vv-hero-dark' %}
{% block title %}Événements | Épicafé{% endblock %}

{% block body %}

{% include 'components/page_banner.html.twig' with {
  title: 'Événements',
  subtitle: 'À venir à l’Épicafé'
} %}

<section class="vv-section vv-section--light">
  <div class="vv-container">
    <div class="vv-section__head vv-scroll-reveal">
      
    
    </div>

    {% if recurringEvents is defined and recurringEvents|length %}
      <div style="height: 2rem;"></div>

      <h2 class="vv-h3" style="margin-bottom: 2rem;">Événements permanents</h2>
      <div class="vv-events">
        {% for event in recurringEvents %}
          {% include 'events/event_row.html.twig' with { event: event } %}
        {% endfor %}
      </div>
    {% endif %}

    <h2 class="vv-h3" style="margin-bottom: 2rem; margin-top: 3rem;">À venir</h2>
    {% if upcomingEvents|length %}
      <div class="vv-events">
        {% for event in upcomingEvents %}
          {% include 'events/_event_row.html.twig' with { event: event } %}
        {% endfor %}
      </div>
    {% else %}
      <p class="vv-muted">Aucun événement à venir.</p>
    {% endif %}

    <div style="height: 2rem;"></div>

    <h2 class="vv-h3" style="margin-bottom: 1rem;">Archives</h2>
    {% if pastEvents|length %}
      <div class="vv-events">
        {% for event in pastEvents %}
          {% include 'events/event_row.html.twig' with { event: event } %}
        {% endfor %}
      </div>
    {% else %}
      <p class="vv-muted">Pas d’archives pour le moment.</p>
    {% endif %}

   
  </div>
</section>
{% endblock %}