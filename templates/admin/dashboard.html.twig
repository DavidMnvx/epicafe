{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Tableau de bord{% endblock %}

{% block main %}
  <div class="vv-admin-dashboard">

    <section class="vv-stats-grid">
      {% for key, stat in stats %}
        <a class="vv-stat-card" href="{{ stat.href }}">
          <div class="vv-stat-card__icon">
            <i class="fa {{ stat.icon }}"></i>
          </div>
          <div class="vv-stat-card__body">
            <div class="vv-stat-card__value">{{ stat.value }}</div>
            <div class="vv-stat-card__label">{{ stat.label }}</div>
          </div>
        </a>
      {% endfor %}
    </section>

   
    {# ============================================================
       PANNEAU AVIS GOOGLE — note moyenne + 3 derniers avis
       ============================================================ #}
    <section class="vv-googleStat">
      <div class="vv-googleStat__head">
        <div class="vv-googleStat__brand">
          <span class="vv-googleStat__g" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="28" height="28" xmlns="http://www.w3.org/2000/svg">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0 0 12 23z" fill="#34A853"/>
              <path d="M5.84 14.11A6.6 6.6 0 0 1 5.5 12c0-.73.13-1.45.34-2.11V7.05H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.46 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.07.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A10.99 10.99 0 0 0 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z" fill="#EA4335"/>
            </svg>
          </span>
          <div>
            <p class="vv-googleStat__kicker">Avis clients · Google</p>
            <h2 class="vv-googleStat__title">Réputation en ligne</h2>
          </div>
        </div>

        <a class="vv-admin-panel__cta" href="{{ reviewsHref }}">
          Gérer les avis <i class="fa fa-arrow-right"></i>
        </a>
      </div>

      {% if reviewStats.count > 0 %}
        {% set avg = reviewStats.average %}
        {% set fullStars = avg|round(0, 'floor')|number_format(0)|number_format(0) %}
        <div class="vv-googleStat__main">
          <div class="vv-googleStat__score">
            <span class="vv-googleStat__num">{{ avg|number_format(1, ',', ' ') }}</span>
            <span class="vv-googleStat__numOver">/ 5</span>
          </div>
          <div class="vv-googleStat__starsBlock">
            <div class="vv-googleStat__stars" aria-label="{{ avg }} étoiles sur 5">
              {% for i in 1..5 %}
                {% if i <= avg %}
                  <span class="vv-googleStat__star is-full">★</span>
                {% else %}
                  <span class="vv-googleStat__star">★</span>
                {% endif %}
              {% endfor %}
            </div>
            <p class="vv-googleStat__count">
              D'après <strong>{{ reviewStats.count }}</strong> avis publié{{ reviewStats.count > 1 ? 's' : '' }}
            </p>
          </div>
        </div>

        {% if latestReviews|length > 0 %}
          <ul class="vv-googleStat__latest">
            {% for r in latestReviews %}
              <li class="vv-googleStat__review">
                <span class="vv-googleStat__avatar" aria-hidden="true">{{ r.author|slice(0, 1)|upper }}</span>
                <div class="vv-googleStat__reviewBody">
                  <div class="vv-googleStat__reviewHead">
                    <strong>{{ r.author }}</strong>
                    <span class="vv-googleStat__reviewStars" aria-hidden="true">
                      {% for i in 1..r.rating %}★{% endfor %}
                    </span>
                    {% if r.reviewDate %}
                      <span class="vv-googleStat__reviewDate">· {{ r.reviewDate|date('M Y')|capitalize }}</span>
                    {% endif %}
                  </div>
                  <p class="vv-googleStat__reviewText">
                    {%- set txt = r.text|striptags|trim -%}
                    {%- if txt|length > 130 -%}
                      « {{ txt|slice(0, 130) }}… »
                    {%- else -%}
                      « {{ txt }} »
                    {%- endif -%}
                  </p>
                </div>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      {% else %}
        <div class="vv-googleStat__empty">
          <span class="vv-googleStat__emptyIcon">⭐</span>
          <p>
            <strong>Aucun avis pour le moment.</strong><br>
            Ajoute les avis Google de tes clients pour les afficher sur le site.
          </p>
          <a href="{{ reviewsHref }}" class="btn btn-primary">
            <i class="fa fa-plus"></i> Ajouter un avis
          </a>
        </div>
      {% endif %}
    </section>

    <section class="vv-admin-panel">
      <header class="vv-admin-panel__head">
        <h2 class="vv-admin-panel__title">Prochains événements</h2>
        <a class="vv-admin-panel__cta" href="{{ links.event }}">
          Voir tout <i class="fa fa-arrow-right"></i>
        </a>
      </header>

      {% if upcomingEvents|length > 0 %}
        <ul class="vv-event-list">
          {% for event in upcomingEvents %}
            {% set when = event.isRecurring
              ? 'Permanent'
              : (event.startAt ? event.startAt|format_datetime('medium', 'short', locale='fr') : '—') %}
            <li class="vv-event-list__item">
              <div class="vv-event-list__when">{{ when }}</div>
              <div class="vv-event-list__title">{{ event.title }}</div>
              <div class="vv-event-list__badge">
                {% if event.isRecurring %}
                  <span class="badge bg-info">Permanent</span>
                {% else %}
                  <span class="badge bg-success">À venir</span>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="vv-admin-panel__empty">Aucun événement à venir pour le moment.</p>
      {% endif %}
    </section>

  </div>
{% endblock %}
