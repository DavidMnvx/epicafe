{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block main %}
  {% if entities|length == 0 %}
    <div class="vv-reviewsAdmin__empty">
      <span class="vv-reviewsAdmin__emptyIcon">⭐</span>
      <h3>Aucun avis pour le moment</h3>
      <p>Ajoute les avis Google de tes clients pour les afficher dans le carousel du site.</p>
    </div>
  {% else %}
    <div class="vv-reviewsAdmin__grid">
      {% for entity in entities %}
        {% set r = entity.instance %}
        {% set edit_url = entity.actions.get('edit') ? entity.actions.get('edit').linkUrl : '#' %}
        {% set delete_url = entity.actions.get('delete') ? entity.actions.get('delete').linkUrl : null %}
        {% set move_up_url = entity.actions.get('moveUp') ? entity.actions.get('moveUp').linkUrl : null %}
        {% set move_down_url = entity.actions.get('moveDown') ? entity.actions.get('moveDown').linkUrl : null %}

        <article class="vv-reviewAdminCard {{ r.isPublished ? '' : 'is-unpublished' }}">

          {# Topbar : ordre + statut publication #}
          <div class="vv-reviewAdminCard__top">
            <span class="vv-reviewAdminCard__pos" title="Ordre d'affichage">#{{ r.position }}</span>
            <span class="vv-reviewAdminCard__publish {{ r.isPublished ? 'is-on' : 'is-off' }}">
              <i class="vv-dot"></i>
              {{ r.isPublished ? 'Publié' : 'Brouillon' }}
            </span>
          </div>

          {# Header : avatar + nom + date #}
          <header class="vv-reviewAdminCard__head">
            <span class="vv-reviewAdminCard__avatar" aria-hidden="true">{{ r.author|slice(0, 1)|upper }}</span>
            <div class="vv-reviewAdminCard__authorBlock">
              <strong class="vv-reviewAdminCard__author">{{ r.author }}</strong>
              {% if r.reviewDate %}
                <span class="vv-reviewAdminCard__date">{{ r.reviewDate|date('d/m/Y') }}</span>
              {% else %}
                <span class="vv-reviewAdminCard__date vv-reviewAdminCard__date--empty">Sans date</span>
              {% endif %}
            </div>
            <span class="vv-reviewAdminCard__google" aria-label="Google" title="Avis Google">
              <svg viewBox="0 0 24 24" width="22" height="22" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A10.99 10.99 0 0 0 12 23z" fill="#34A853"/>
                <path d="M5.84 14.11A6.6 6.6 0 0 1 5.5 12c0-.73.13-1.45.34-2.11V7.05H2.18A10.97 10.97 0 0 0 1 12c0 1.78.43 3.46 1.18 4.95l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.07.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1A10.99 10.99 0 0 0 2.18 7.05l3.66 2.84C6.71 7.31 9.14 5.38 12 5.38z" fill="#EA4335"/>
              </svg>
            </span>
          </header>

          {# Étoiles #}
          <div class="vv-reviewAdminCard__stars" aria-label="{{ r.rating }} étoiles sur 5">
            {% for i in 1..r.rating %}★{% endfor %}
            {% if r.rating < 5 %}
              {% for i in 1..(5 - r.rating) %}<span class="vv-reviewAdminCard__starEmpty">★</span>{% endfor %}
            {% endif %}
          </div>

          {# Texte de l'avis #}
          <p class="vv-reviewAdminCard__text">« {{ r.text }} »</p>

          {# Boutons réordonnancement #}
          <div class="vv-reviewAdminCard__order">
            {% if move_up_url %}
              <a href="{{ move_up_url }}" class="vv-reviewAdminCard__orderBtn" title="Monter">
                <i class="fa fa-arrow-up"></i>
              </a>
            {% else %}
              <span class="vv-reviewAdminCard__orderBtn is-disabled" title="Déjà en haut"><i class="fa fa-arrow-up"></i></span>
            {% endif %}
            {% if move_down_url %}
              <a href="{{ move_down_url }}" class="vv-reviewAdminCard__orderBtn" title="Descendre">
                <i class="fa fa-arrow-down"></i>
              </a>
            {% else %}
              <span class="vv-reviewAdminCard__orderBtn is-disabled" title="Déjà en bas"><i class="fa fa-arrow-down"></i></span>
            {% endif %}
          </div>

          {# Footer : actions #}
          <footer class="vv-reviewAdminCard__foot">
            <a href="{{ edit_url }}" class="btn btn-primary">
              <i class="fa fa-pen"></i> Modifier
            </a>
            {% if delete_url %}
              <a href="{{ delete_url }}" class="btn btn-link text-danger" data-bs-toggle="modal" data-bs-target="#modal-delete">
                <i class="fa fa-trash"></i>
              </a>
            {% endif %}
          </footer>
        </article>
      {% endfor %}
    </div>

    {% if paginator.hasPreviousPage or paginator.hasNextPage %}
      <div class="datagrid-pagination-wrapper mt-4">
        {{ include('@EasyAdmin/crud/paginator.html.twig') }}
      </div>
    {% endif %}
  {% endif %}

  {% block delete_form %}
    {{ include('@EasyAdmin/crud/includes/_delete_form.html.twig') }}
  {% endblock delete_form %}
{% endblock main %}
