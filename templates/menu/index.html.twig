{% extends 'base_front.html.twig' %}
{% set bodyClass = 'vv-hero-dark vv-hero-img' %}
{% block title %}Menu | L'Épi-Café{% endblock %}

{% block preloads %}
  <link rel="preload" as="image" href="{{ site_image('banner_menu', 'images/banners-menu.png') }}" fetchpriority="high">
{% endblock %}

{# Mapping icône par section (utilisé dans le sommaire et les titres) #}
{% set sectionIcons = {
  'SNACK':    '🍔',
  'BOISSONS': '🥤',
  'ALCOOL':   '🍷',
} %}

{% macro render_item(i) %}
  {% if i.isPublished %}
    {% set hasPricedVariants = false %}
    {% if i.variants|length > 0 %}
      {% for v in i.variants %}
        {% if v.price is not empty %}
          {% set hasPricedVariants = true %}
        {% endif %}
      {% endfor %}
    {% endif %}

    <div class="vv-menu-line">
      <div class="vv-menu-left">
        <span class="vv-menu-name">{{ i.name }}</span>

        {% if i.unit %}
          <span class="vv-menu-desc">{{ i.unit }}</span>
        {% endif %}

        {% if i.description %}
          <span class="vv-menu-desc">{{ i.description }}</span>
        {% endif %}

        {% if i.note %}
          <span class="vv-menu-desc">{{ i.note }}</span>
        {% endif %}
      </div>

      {% if i.price and (i.variants|length == 0 or not hasPricedVariants) %}
        <div class="vv-menu-price">{{ i.price|number_format(2, ',', ' ') }}€</div>
      {% endif %}
    </div>

    {% if i.variants|length > 0 %}
      {% for v in i.variants %}
        <div class="vv-menu-variant-line">
          <span class="vv-menu-variant-name">{{ v.label }}</span>

          {% if hasPricedVariants and v.price %}
            <span class="vv-menu-price">{{ v.price|number_format(2, ',', ' ') }}€</span>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}
  {% endif %}
{% endmacro %}

{% import _self as menu %}

{% block body %}

{% include 'components/page_banner.html.twig' with {
  title: 'Menu',
  subtitle: 'Boissons, produits du terroir et plaisirs simples à déguster au cœur du village.',
  background: site_image('banner_menu', 'images/banners-menu.png'),
  bgClass: 'vv-miniHero--menu'
} %}

<section class="vv-section vv-section--light">
  <div class="vv-container">

    <div class="vv-section__head vv-scroll-reveal">
      <p class="vv-kicker">À déguster</p>
      <h2 class="vv-h2">La carte</h2>
      <p class="vv-lead">Une présentation pensée comme une vraie carte de bistrot : snack, boissons et alcool.</p>
    </div>

    {# ============================================================
       SOMMAIRE STICKY — chips de navigation entre sections
       ============================================================ #}
    {% set sectionOrder = ['SNACK', 'BOISSONS', 'ALCOOL'] %}

    <nav class="vv-menuSommaire vv-scroll-reveal" aria-label="Sommaire de la carte" data-menu-sommaire>
      <span class="vv-menuSommaire__label">Aller à&nbsp;:</span>
      <ul class="vv-menuSommaire__list">
        {% for sectionName in sectionOrder %}
          {% set sectionCategory = null %}
          {% for cat in rootCategories %}
            {% if cat.isPublished and cat.name|upper == sectionName %}
              {% set sectionCategory = cat %}
            {% endif %}
          {% endfor %}

          {% if sectionCategory %}
            {% set anchor = 'menu-' ~ sectionName|lower %}

            {# Calcul inline du nombre d'items publiés (items directs + sous-catégories) #}
            {% set count = 0 %}
            {% for i in sectionCategory.items %}
              {% if i.isPublished %}{% set count = count + 1 %}{% endif %}
            {% endfor %}
            {% for sub in sectionCategory.children %}
              {% if sub.isPublished %}
                {% for i in sub.items %}
                  {% if i.isPublished %}{% set count = count + 1 %}{% endif %}
                {% endfor %}
              {% endif %}
            {% endfor %}

            <li>
              <a href="#{{ anchor }}"
                 class="vv-menuSommaire__chip"
                 data-section-link="{{ anchor }}">
                <span class="vv-menuSommaire__icon" aria-hidden="true">{{ sectionIcons[sectionName] ?? '·' }}</span>
                <span class="vv-menuSommaire__name">{{ sectionCategory.name }}</span>
                {% if count > 0 %}
                  <span class="vv-menuSommaire__count">{{ count }}</span>
                {% endif %}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </nav>

    {# ============================================================
       SECTIONS DE LA CARTE
       ============================================================ #}
    {% for sectionName in sectionOrder %}
      {% set sectionCategory = null %}

      {% for cat in rootCategories %}
        {% if cat.isPublished and cat.name|upper == sectionName %}
          {% set sectionCategory = cat %}
        {% endif %}
      {% endfor %}

      {% if sectionCategory %}
        {% set anchor = 'menu-' ~ sectionName|lower %}
        <section id="{{ anchor }}"
                 class="vv-menuSection vv-scroll-reveal"
                 data-section="{{ anchor }}">
          <div class="vv-menuSection__head">
            <span class="vv-menuSection__icon" aria-hidden="true">{{ sectionIcons[sectionName] ?? '' }}</span>
            <h2 class="vv-menuSection__title">{{ sectionCategory.name }}</h2>
          </div>

          {% set blocks = [] %}

          {% if sectionCategory.items|length > 0 %}
            {% set blocks = blocks|merge([{
              title: null,
              items: sectionCategory.items
            }]) %}
          {% endif %}

          {% for sub in sectionCategory.children %}
            {% if sub.isPublished and sub.items|length > 0 %}
              {% set blocks = blocks|merge([{
                title: sub.name,
                items: sub.items
              }]) %}
            {% endif %}
          {% endfor %}

          <div class="vv-menuSection__grid">
            {% for block in blocks %}
              <div class="vv-menuSubblock">
                {% if block.title %}
                  <h3 class="vv-menuSubblock__title">{{ block.title }}</h3>
                {% endif %}

                <div class="vv-menuSubblock__body">
                  {% for i in block.items %}
                    {{ menu.render_item(i) }}
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>

          {# Loi Évin : mention obligatoire sous toute publicité de boissons alcoolisées #}
          {% if sectionName == 'ALCOOL' %}
            <p class="vv-menuLegal vv-menuLegal--evin" role="note">
              <span aria-hidden="true">⚠</span>
              <em>L'abus d'alcool est dangereux pour la santé. À consommer avec modération.</em>
            </p>
          {% endif %}
        </section>
      {% endif %}
    {% endfor %}

    {# ============================================================
       MENTIONS LÉGALES DE LA CARTE — allergènes, origine, fait maison
       ============================================================ #}
    <aside class="vv-menuFootnotes vv-scroll-reveal" aria-label="Informations légales sur la carte">
      <h3 class="vv-menuFootnotes__title">Bon à savoir</h3>

      <div class="vv-menuFootnotes__grid">

        <div class="vv-menuFootnote">
          <span class="vv-menuFootnote__icon" aria-hidden="true">🌾</span>
          <div>
            <strong>Allergènes</strong>
            <p>La liste des allergènes présents dans nos préparations est disponible sur simple demande au comptoir.</p>
          </div>
        </div>

        <div class="vv-menuFootnote">
          <span class="vv-menuFootnote__icon" aria-hidden="true">👨‍🍳</span>
          <div>
            <strong>Fait maison</strong>
            <p>Une grande partie de notre carte est préparée sur place à partir de produits bruts. N'hésitez pas à nous demander.</p>
          </div>
        </div>

        <div class="vv-menuFootnote">
          <span class="vv-menuFootnote__icon" aria-hidden="true">📍</span>
          <div>
            <strong>Origine & saison</strong>
            <p>Nos viandes, fromages et légumes sont sélectionnés en priorité auprès de producteurs locaux. La carte évolue selon les saisons et arrivages.</p>
          </div>
        </div>

      </div>

      <p class="vv-menuFootnotes__note">
        Prix nets en euros (TTC), service compris.
      </p>
    </aside>

  </div>
</section>

{# ============================================================
   CTA — réservation, événements
   ============================================================ #}
<section class="vv-section vv-section--cream">
  <div class="vv-container">
    <div class="vv-menuCta">
      <div class="vv-menuCta__inner">

        <div class="vv-menuCta__text">
          <h2>Envie de passer un bon moment ?</h2>
          <p>Réservez votre table ou découvrez les prochains événements de l'Épi-Café.</p>
        </div>

        <div class="vv-menuCta__actions">
          <a href="{{ path('contact_index') }}" class="vv-btn vv-btn--primary">
            📅 Réserver
          </a>

          <a href="{{ path('event_index') }}" class="vv-btn vv-btn--ghost">
            🎶 Voir les événements
          </a>

          <a href="{{ path('contact_index') }}#contact" class="vv-btn vv-btn--ghost">
            📞 Nous contacter
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

{# ============================================================
   BOUTON "Retour en haut" flottant — visible après scroll
   ============================================================ #}
<button type="button"
        class="vv-backToTop"
        aria-label="Retour en haut de la page"
        data-back-to-top>
  <span aria-hidden="true">↑</span>
</button>

{# ============================================================
   JS : highlight section active + back-to-top
   ============================================================ #}
<script>
  (function() {
    // 1) Highlight section active dans le sommaire au scroll
    const links = document.querySelectorAll('[data-section-link]');
    const sections = document.querySelectorAll('[data-section]');

    if (sections.length && 'IntersectionObserver' in window) {
      const linkByAnchor = {};
      links.forEach(l => { linkByAnchor[l.dataset.sectionLink] = l; });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const link = linkByAnchor[entry.target.dataset.section];
          if (!link) return;
          if (entry.isIntersecting) {
            links.forEach(l => l.classList.remove('is-active'));
            link.classList.add('is-active');
          }
        });
      }, { rootMargin: '-30% 0px -55% 0px', threshold: 0 });

      sections.forEach(s => observer.observe(s));
    }

    // 2) Bouton "retour en haut" — apparaît après 300px de scroll
    const backBtn = document.querySelector('[data-back-to-top]');
    if (backBtn) {
      const toggle = () => {
        backBtn.classList.toggle('is-visible', window.scrollY > 300);
      };
      window.addEventListener('scroll', toggle, { passive: true });
      toggle();
      backBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  })();
</script>

{% endblock %}
