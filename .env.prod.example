# =============================================================================
# Variables d'environnement PRODUCTION
# À copier-coller dans Coolify (Project → Environment Variables) en ajustant.
# Ne pas commiter .env.prod (qui contient les vrais secrets).
# =============================================================================

# --- Symfony ---
APP_ENV=prod
APP_DEBUG=0
# IMPORTANT : générer un nouveau secret pour la prod
# Commande pour générer : openssl rand -hex 32
APP_SECRET=REMPLACE_PAR_UN_VRAI_SECRET_HEX_DE_64_CARACTERES

# URL canonique du site (utilisée pour générer les URL absolues, OG, etc.)
DEFAULT_URI=https://epicafebarroux.fr

# --- Postgres ---
# Crée des credentials forts spécifiques à la prod
POSTGRES_DB=epicafe
POSTGRES_USER=epicafe_prod
POSTGRES_PASSWORD=REMPLACE_PAR_UN_MOT_DE_PASSE_FORT

# --- Mailer (Brevo SMTP) ---
# Récupère USER + KEY dans le dashboard Brevo → SMTP & API
# Format : smtp://USER:KEY@smtp-relay.brevo.com:587
MAILER_DSN=smtp://REMPLACE_USER:REMPLACE_KEY@smtp-relay.brevo.com:587
